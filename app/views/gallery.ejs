<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%
    // Add an og-image using the first image's thumbnail
    if (items?.[0]?.previewUrl) {
    %>
        <meta property="og:title" content="<%= title %>">
        <meta property="og:image" content="<%- publicBaseUrl %><%- items[0].previewUrl %>">
        <meta name="twitter:title" content="<%= title %>">
        <meta name="twitter:image" content="<%- publicBaseUrl %><%- items[0].previewUrl %>">
        <meta name="twitter:card" content="summary_large_image">
    <% } %>
    <link rel="icon" href="/share/static/favicon.ico" type="image/x-icon">
    <link type="text/css" rel="stylesheet" href="/share/static/style.css"/>
    <link type="text/css" rel="stylesheet" href="/share/static/lg/lightgallery-bundle.min.css"/>
    <%
    const hasGpsItems = items.some(i => i.latitude != null && i.longitude != null);
    if (showMap && hasGpsItems) {
    %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <% } %>
</head>
<body>
<div id="header">
    <% if (showTitle) { %>
        <h1><%= title || 'Gallery' %></h1>
    <% } %>
    <%
    if (showDownload) {
    %>
        <div id="download-all">
            <a href="<%- path %>/download" title="Download all"><img src="/share/static/images/download-all.svg"
                                                                     height="24"
                                                                     width="24" alt="Download all"></a>
        </div>
    <% } %>
</div>
<% if (description) { %>
    <div id="album-description">
        <h2><%= description %></h2>
    </div>
<% } %>
<div id="lightgallery">
    <%
    // Load the first 50 thumbnails, then load more as the user scrolls. See web.js
    items.slice(0, 50).forEach(item => {
    %><%- item.html %>
    <% }) %>
</div>
<% if (items.length > 50) { %><div id="loading-spinner"><span class="loader"></span></div><% } %>
<%
const gpsItems = items.map((item, idx) => ({ ...item, idx })).filter(i => i.latitude != null && i.longitude != null);
if (showMap && gpsItems.length > 0) {
%>
<div id="map-container">
  <h3>📍 Locations</h3>
  <div id="map"></div>
</div>
<script>
(function() {
  const gpsData = <%- JSON.stringify(gpsItems.map(i => ({ lat: i.latitude, lng: i.longitude, thumb: i.thumbnailUrl, index: i.idx }))) %>;
  const map = L.map('map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    maxZoom: 19
  }).addTo(map);
  const markers = [];
  gpsData.forEach(function(item) {
    const marker = L.marker([item.lat, item.lng]).addTo(map);
    if (item.thumb) {
      const img = document.createElement('img');
      img.src = item.thumb;
      img.style.cssText = 'max-width:150px;max-height:150px;border-radius:4px;cursor:pointer;';
      img.title = 'Click to view full size';
      img.addEventListener('click', function() {
        marker.closePopup();
        lgallery.openAtIndex(item.index);
      });
      marker.bindPopup(img);
    }
    markers.push(marker);
  });
  if (markers.length === 1) {
    map.setView([gpsData[0].lat, gpsData[0].lng], 14);
  } else {
    const group = L.featureGroup(markers);
    map.fitBounds(group.getBounds().pad(0.1));
  }

  // Fullscreen control
  const ICON_EXPAND = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M1 1h4V0H0v5h1V1zm8-1v1h4v4h1V0H9zm4 13H9v1h5V9h-1v4zM1 9H0v5h5v-1H1V9z"/></svg>';
  const ICON_COMPRESS = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M5 0H4v4H0v1h5V0zm4 0v5h5V4H9V0H8zM0 9v1h4v4h1V9H0zm9 5h1V9H5v1h4v4z"/></svg>';

  const FullscreenControl = L.Control.extend({
    options: { position: 'topleft' },
    _fsHandler: null,
    onAdd: function (m) {
      const container = L.DomUtil.create('div', 'leaflet-bar leaflet-control leaflet-control-fullscreen');
      const btn = L.DomUtil.create('a', '', container);
      btn.href = '#';
      btn.title = 'Plein écran';
      btn.setAttribute('role', 'button');
      btn.innerHTML = ICON_EXPAND;

      function updateIcon () {
        if (document.fullscreenElement) {
          btn.title = 'Quitter le plein écran';
          btn.innerHTML = ICON_COMPRESS;
        } else {
          btn.title = 'Plein écran';
          btn.innerHTML = ICON_EXPAND;
        }
      }

      this._fsHandler = function () {
        updateIcon();
        m.invalidateSize();
      };

      L.DomEvent.on(btn, 'click', function (e) {
        L.DomEvent.stopPropagation(e);
        L.DomEvent.preventDefault(e);
        const mapEl = m.getContainer();
        if (!document.fullscreenElement) {
          mapEl.requestFullscreen();
        } else {
          document.exitFullscreen();
        }
      });

      document.addEventListener('fullscreenchange', this._fsHandler);

      return container;
    },
    onRemove: function () {
      if (this._fsHandler) {
        document.removeEventListener('fullscreenchange', this._fsHandler);
        this._fsHandler = null;
      }
    }
  });
  new FullscreenControl().addTo(map);
})();
</script>
<% } %>
<script src="/share/static/web.js"></script>
<script src="/share/static/lg/lightgallery.min.js"></script>
<script src="/share/static/lg/lg-fullscreen.min.js"></script>
<script src="/share/static/lg/lg-thumbnail.min.js"></script>
<script src="/share/static/lg/lg-video.min.js"></script>
<script src="/share/static/lg/lg-zoom.min.js"></script>
<script src="/share/static/lg/lg-hash.min.js"></script>
<script type="text/javascript">
  lgallery.init(<%- JSON.stringify({
      lgConfig,
      items,
      openItem
  }) %>) // initLightGallery imported from web.js
  <% if (openItem) { %>
  const openItem = <%- openItem %>
  const thumbs = document.querySelectorAll('#lightgallery a')
  if (thumbs.length >= openItem) {
    thumbs[openItem - 1].click()
  }
  <% } %>
</script>
</body>
</html>
